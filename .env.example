# ===========================================
# Training Market — Environment Configuration
# ===========================================

# Database
DATABASE_URL=postgresql://tm_admin:tm_password@localhost:5432/training_market
DATABASE_POOL_SIZE=20

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-jwt-secret-change-this
JWT_REFRESH_SECRET=your-jwt-refresh-secret-change-this
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# API Server
API_PORT=4000
API_BASE_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000

# Web Frontend
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Payment Gateway (Stripe or Billplz)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# BILLPLZ_API_KEY=
# BILLPLZ_COLLECTION_ID=

# AI Provider
AI_PROVIDER=openai
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Email (SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@trainingmarket.my

# Firebase (Mobile Push Notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Object Storage (S3-compatible)
STORAGE_ENDPOINT=
STORAGE_BUCKET=training-market
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=ap-southeast-1

# App
NODE_ENV=development
LOG_LEVEL=debug
